{
  "name": "tingyun-capture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "test-site": "tsx src/test-site/server.ts",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsx src/main.ts start --no-open-sidecar\"",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "yauzl": "^3.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
